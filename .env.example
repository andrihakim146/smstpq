# ─── Salin file ini menjadi .env dan isi nilainya ─────────────────────────────
# cp .env.example .env

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# URL dengan connection pooler (Transaction mode) untuk serverless Netlify
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# URL langsung (Direct mode) — digunakan oleh prisma migrate / prisma studio
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── JWT Session (PIN login) ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secure-jwt-secret-min-32-chars"

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BL..."
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@your-domain.com"

# ─── Aplikasi ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-site.netlify.app"
NODE_ENV="production"

# ─── Cron Job Protection ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-secure-cron-secret-min-32-chars"

# ─── Konfigurasi Retensi Data ─────────────────────────────────────────────────
RETENTION_MONTHS="6"
