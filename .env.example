# ─── Salin file ini menjadi .env dan isi nilainya ─────────────────────────────
# cp .env.example .env

# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# NETLIFY / SERVERLESS: gunakan Connection Pooler — Transaction mode (port 6543)
# Supabase Dashboard → Project Settings → Database → Connection string → Transaction pooler
# Contoh format:
# DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"

# URL langsung (Direct mode, port 5432) — untuk prisma migrate / prisma studio LOKAL saja
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require"

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ─── JWT Session (PIN login) ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-secure-jwt-secret-min-32-chars"

# ─── Web Push (VAPID) ─────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="BL..."
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@your-domain.com"

# ─── Aplikasi ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-site.netlify.app"
NODE_ENV="production"

# ─── Cron Job Protection ───────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET="your-secure-cron-secret-min-32-chars"

# ─── Konfigurasi Retensi Data ─────────────────────────────────────────────────
RETENTION_MONTHS="6"
